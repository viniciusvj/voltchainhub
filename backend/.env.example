# VoltChainHub Backend Configuration

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=voltchain

# Blockchain (Polygon PoS)
RPC_URL=https://polygon-rpc.com
CHAIN_ID=137
ORACLE_PRIVATE_KEY=0x_YOUR_ORACLE_PRIVATE_KEY_HERE
ENERGY_ORACLE_ADDRESS=0x_ENERGY_ORACLE_CONTRACT_ADDRESS
LUZ_TOKEN_ADDRESS=0x_LUZ_TOKEN_CONTRACT_ADDRESS
DEVICE_REGISTRY_ADDRESS=0x_DEVICE_REGISTRY_CONTRACT_ADDRESS
ENERGY_VAULT_ADDRESS=0x_ENERGY_VAULT_CONTRACT_ADDRESS

# SQLite
DB_PATH=./data/voltchain.db

# OpenEMS Edge
OPENEMS_URL=http://localhost:8084
OPENEMS_USERNAME=admin
OPENEMS_PASSWORD=admin

# Market
MARKET_CYCLE_SECONDS=300
MIN_MARKET_PARTICIPANTS=2
ANOMALY_ZSCORE_THRESHOLD=3.0
ORACLE_BATCH_INTERVAL_SECONDS=60

# Timestamp drift tolerance (seconds)
TIMESTAMP_DRIFT_TOLERANCE=600
